{
  "manifest_version": 3,
  "name": "Spoiler Free Threads",
  "version": "1.1",
  "description": "Automatically reveals spoiler content on Threads",
  "icons": {
    "16": "images/icon16.png",
    "32": "images/icon32.png",
    "48": "images/icon48.png",
    "128": "images/icon128.png"
  },
  "permissions": ["storage", "activeTab"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Spoiler Free Threads"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://*.threads.com/*", "*://*.threads.net/*"],
      "js": ["script.js"],
      "run_at": "document_end"
    }
  ]
}
